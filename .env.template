# Design Supporter - Environment Variable Template
# Copy this file to .env and fill in the actual values. DO NOT commit .env files to Git.

# --- API Keys ---
# Groq API Key (If testing external LLM worker locally)
GROQ_API_KEY=your_groq_api_key_here

# Notion API Token (If integrating Notion DB)
NOTION_TOKEN=your_notion_secret_token_here

# Firebase Admin SDK path or JSON string (If used)
FIREBASE_CREDENTIALS=your_firebase_credentials_here

# --- Application Settings ---
# Base URL for local development components
NEXT_PUBLIC_API_URL=http://localhost:3000

# Desktop Agent / Electron Settings
PORT=3000
DEBUG=false
